include includes/head.pug
include includes/navbar.pug

main.container.py-8
  if error
    p.text-red-400.mb-4 Аккаунт уже зарегистрирован на эту почту
  form(method="post" action="/register" class="max-w-md mx-auto bg-card p-6 rounded-lg shadow-md")
    h2(class="text-2xl font-semibold mb-4 text-white") Регистрация
    input(type="email" name="mail" placeholder= "Email" class="w-full mb-3 p-3 rounded border bg-transparent text-white border-gray-600")
    input(type="text" name="name" placeholder="Имя" class="w-full mb-3 p-3 rounded border bg-transparent text-white border-gray-600")
    input(type="password" name="password" placeholder="Пароль" class="w-full mb-3 p-3 rounded border bg-transparent text-white border-gray-600")
    input(type="text" name="year" placeholder="Год" class="w-full mb-4 p-3 rounded border bg-transparent text-white border-gray-600")
    input(type="submit" value="Зарегистрироваться" class="w-full bg-accent text-black py-2 rounded")
